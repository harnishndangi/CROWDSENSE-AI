{
  "_meta": {
    "project": "CrowdSense Mumbai",
    "version": "1.0.0",
    "inspiration": [
      "M Indicator Redesign UI Kit – Dribbble #6033723",
      "M Indicator Train Live Tracking – Dribbble #23035638",
      "M Indicator Onboarding Interaction – Dribbble #5897983"
    ],
    "description": "Design token system derived from M Indicator's Mumbai-native transit UI language. Dark navy base, high-contrast orange brand, crowd-severity scale (green → amber → orange → red), monospace data numerics.",
    "last_updated": "2026-03-28"
  },

  "color": {

    "brand": {
      "primary":       { "hex": "#F97316", "name": "Mumbai Orange",   "usage": "Logo, CTAs, active tab indicators, key highlights" },
      "primary_dark":  { "hex": "#C2570A", "name": "Deep Orange",     "usage": "Pressed state, hover on primary" },
      "primary_light": { "hex": "#FED7AA", "name": "Soft Orange",     "usage": "Orange tinted backgrounds, badges" },
      "primary_glow":  { "hex": "#F9731620", "name": "Orange Glow",  "usage": "Subtle glow ring on active elements" }
    },

    "background": {
      "base":          { "hex": "#0B0F1A", "name": "Midnight Navy",   "usage": "App root background — darkest surface" },
      "surface":       { "hex": "#111827", "name": "Deep Navy",       "usage": "Main panel background" },
      "elevated":      { "hex": "#1A2035", "name": "Card Navy",       "usage": "Cards, sidebars, modals" },
      "overlay":       { "hex": "#1F2845", "name": "Hover Navy",      "usage": "Hover states, row highlights" },
      "border":        { "hex": "#2A3352", "name": "Subtle Border",   "usage": "Dividers, card borders" },
      "border_strong": { "hex": "#3B4A6B", "name": "Strong Border",  "usage": "Active/focused element borders" }
    },

    "text": {
