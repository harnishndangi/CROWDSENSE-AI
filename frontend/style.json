    "3":  "12px",
    "4":  "16px",
    "5":  "20px",
    "6":  "24px",
    "8":  "32px",
    "10": "40px",
    "12": "48px",
    "16": "64px",
    "20": "80px",

    "semantic": {
      "card_padding":         "16px 20px",
      "card_padding_compact": "12px 16px",
      "sidebar_padding":      "16px 12px",
      "section_gap":          "12px",
      "inline_gap":           "8px",
      "icon_text_gap":        "6px",
      "list_item_gap":        "4px"
    }
  },

  "border_radius": {
    "none":   "0px",
    "sm":     "4px",
    "md":     "8px",
    "lg":     "12px",
    "xl":     "16px",
    "2xl":    "20px",
    "pill":   "9999px",

