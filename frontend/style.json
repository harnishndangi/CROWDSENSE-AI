    "custom_css_notes": [
      "Use st.set_page_config(layout='wide', page_title='CrowdSense Mumbai') to enable wide layout",
      "Inject <style> block via st.markdown to override .stSidebar, .stMetric, .stButton",
      "Metric values: font-family monospace, color #F97316 for crowd-coded values",
      "Tab active underline: border-bottom: 2px solid #F97316",
      "Hide Streamlit default hamburger and footer via style injection"
    ]
