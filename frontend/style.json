  "typography": {

    "font_family": {
      "display":  "'Plus Jakarta Sans', 'Inter', sans-serif",
      "body":     "'Inter', 'SF Pro Text', sans-serif",
      "mono":     "'JetBrains Mono', 'Fira Code', monospace",
      "_note":    "Mono is used for ALL numeric data values — confidence %, crowd counts, timestamps, feature importance scores. This is the M Indicator influence: numbers feel precise and scannable."
    },

    "scale": {
      "display_xl": { "size": "32px", "weight": 700,  "line_height": 1.2,  "usage": "App name in splash/onboarding" },
      "display_lg": { "size": "28px", "weight": 700,  "line_height": 1.25, "usage": "Hero crowd level label (VERY HIGH)" },
      "heading_1":  { "size": "22px", "weight": 600,  "line_height": 1.3,  "usage": "Section titles, tab headers" },
      "heading_2":  { "size": "18px", "weight": 600,  "line_height": 1.35, "usage": "Card titles, location names" },
      "heading_3":  { "size": "15px", "weight": 500,  "line_height": 1.4,  "usage": "Subsection labels, sidebar items" },
      "body_lg":    { "size": "15px", "weight": 400,  "line_height": 1.6,  "usage": "Reason explanations, descriptions" },
      "body_md":    { "size": "13px", "weight": 400,  "line_height": 1.6,  "usage": "Default body, card content" },
      "body_sm":    { "size": "12px", "weight": 400,  "line_height": 1.5,  "usage": "Meta info, timestamps, source badges" },
      "label":      { "size": "11px", "weight": 500,  "line_height": 1.4,  "usage": "ALL CAPS section labels, nav items" },
      "mono_xl":    { "size": "36px", "weight": 700,  "font": "mono",      "usage": "Confidence percentage hero number" },
      "mono_lg":    { "size": "24px", "weight": 600,  "font": "mono",      "usage": "Crowd score, prediction confidence in cards" },
      "mono_md":    { "size": "14px", "weight": 500,  "font": "mono",      "usage": "Feature importance values, hour labels" },
      "mono_sm":    { "size": "11px", "weight": 400,  "font": "mono",      "usage": "Timestamps, axis labels, version numbers" }
    },

    "case": {
      "section_label": "UPPERCASE with 0.08em letter-spacing",
      "nav_item":      "Sentence case",
      "crowd_level":   "UPPERCASE — LOW / MEDIUM / HIGH / VERY HIGH",
      "button":        "Sentence case"
    }
  },

  "spacing": {
    "_unit": "4px base grid — all values are multiples of 4",
