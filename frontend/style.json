  "animation": {
    "duration": {
      "fast":   "120ms",
      "normal": "200ms",
      "slow":   "350ms",
      "pulse":  "2s"
    },
    "easing": {
      "default":  "cubic-bezier(0.4, 0, 0.2, 1)",
      "in":       "cubic-bezier(0.4, 0, 1, 1)",
      "out":      "cubic-bezier(0, 0, 0.2, 1)",
      "spring":   "cubic-bezier(0.34, 1.56, 0.64, 1)"
    },
    "keyframes": {
      "pulse_dot":    "0%,100% { opacity:1 } 50% { opacity:0.35 }",
      "trace_appear": "from { opacity:0; transform:translateY(4px) } to { opacity:1; transform:translateY(0) }",
      "bar_grow":     "from { transform:scaleY(0) } to { transform:scaleY(1) }",
      "card_in":      "from { opacity:0; transform:translateY(8px) } to { opacity:1; transform:translateY(0) }"
    }
  },

  "layout": {
    "max_width":        "1440px",
    "sidebar_width":    "220px",
    "right_panel_width":"200px",
    "topbar_height":    "52px",
