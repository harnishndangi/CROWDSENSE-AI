    "column_gap":       "0px",

    "grid": {
      "desktop":  "220px 1fr 200px",
      "tablet":   "1fr",
      "mobile":   "1fr",
      "breakpoints": {
        "mobile":  "640px",
        "tablet":  "1024px",
        "desktop": "1280px"
      }
    }
  },

