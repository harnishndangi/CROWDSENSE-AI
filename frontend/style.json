      "cached":   { "hex": "#F59E0B", "bg": "#78350F30", "border": "#F59E0B40", "label": "Serving cached data" },
      "error":    { "hex": "#EF4444", "bg": "#7F1D1D30", "border": "#EF444440", "label": "API or model error" },
