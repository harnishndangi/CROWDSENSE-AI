      "secondary": { "hex": "#9CA3B8", "name": "Cool Gray",    "usage": "Subtitles, descriptions, muted labels" },
      "tertiary":  { "hex": "#4B5472", "name": "Dim Slate",    "usage": "Placeholders, disabled text, timestamps" },
      "inverse":   { "hex": "#0B0F1A", "name": "Dark Ink",     "usage": "Text on light/orange backgrounds" },
      "accent":    { "hex": "#F97316", "name": "Orange Text",  "usage": "Highlighted values, links, active items" }
    },

