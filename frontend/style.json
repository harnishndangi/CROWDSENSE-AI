        "hex_dim":      "#15803D",
        "hex_bg":       "#14532D25",
        "hex_border":   "#22C55E40",
        "text":         "#4ADE80",
        "usage":        "Crowd level Low — platforms clear, safe to travel"
      },
      "medium": {
        "label":        "Medium",
        "hex":          "#EAB308",
        "hex_dim":      "#A16207",
        "hex_bg":       "#71350025",
        "hex_border":   "#EAB30840",
        "text":         "#FDE047",
        "usage":        "Crowd level Medium — moderate crowding, manageable"
      },
      "high": {
        "label":        "High",
        "hex":          "#F97316",
        "hex_dim":      "#C2570A",
        "hex_bg":       "#7C2D1225",
        "hex_border":   "#F9731640",
        "text":         "#FB923C",
        "usage":        "Crowd level High — busy, plan accordingly"
      },
      "very_high": {
        "label":        "Very High",
        "hex":          "#EF4444",
        "hex_dim":      "#B91C1C",
        "hex_bg":       "#7F1D1D25",
        "hex_border":   "#EF444450",
        "text":         "#F87171",
        "usage":        "Crowd level Very High — severe crowding, avoid or delay"
      }
